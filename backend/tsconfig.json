{
    "compilerOptions": {
        "outDir": "./dist",
        "target": "ES2022",
        "module": "esnext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "types": ["node"]
    },
    "include": ["src", "scripts", "drizzle.config.ts"],
    "exclude": ["node_modules", "dist"]
}
